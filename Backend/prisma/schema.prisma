// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  phone       String    @unique
  email       String    @unique
  password    String
  role        String    @default("USER")
  company     Company?
  purchaseOrders PurchaseOrder[] @relation("UserPurchaseOrders")
  reviewedOrders PurchaseOrder[] @relation("AdminReviewedOrders")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("users")
}

model Company {
  id                    String    @id @default(auto()) @map("_id") @db.ObjectId
  userId                String    @unique @db.ObjectId
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName           String
  companySize           String
  yearOfEstablishment   Int
  gstNumber             String    @unique
  panNumber             String?
  companyPhone          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("companies")
}

model PurchaseOrder {
  id                    String      @id @default(auto()) @map("_id") @db.ObjectId
  uniqueId              String      @unique
  userId                String      @db.ObjectId
  user                  User        @relation("UserPurchaseOrders", fields: [userId], references: [id], onDelete: Cascade)
  status                String      @default("PENDING")
  reviewNote            String?
  reviewedAt            DateTime?
  reviewedById          String?     @db.ObjectId
  reviewedBy            User?       @relation("AdminReviewedOrders", fields: [reviewedById], references: [id], onDelete: SetNull)
  companyName           String
  companyAddress        String
  companyCityStateZip   String
  companyCountry        String
  companyContact        String?
  vendorName            String
  vendorAddress         String
  vendorCityStateZip    String
  vendorCountry         String
  poNumber              String
  orderDate             DateTime?
  deliveryDate          DateTime?
  subTotal              Float
  taxRate               Float?
  taxAmount             Float?
  total                 Float
  lineItems             LineItem[]
  trucks                TruckAllocation[]
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@map("purchase_orders")
}

model LineItem {
  id                String          @id @default(auto()) @map("_id") @db.ObjectId
  purchaseOrderId   String          @db.ObjectId
  purchaseOrder     PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  description       String
  quantity          Int
  rate              Float
  amount            Float
  gst               Float?
  truckAllocations  TruckAllocation[]
  truckDeliveredItems TruckDeliveredItem[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("line_items")
}

model TruckAllocation {
  id                String              @id @default(auto()) @map("_id") @db.ObjectId
  purchaseOrderId   String              @db.ObjectId
  purchaseOrder     PurchaseOrder       @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  lineItemId        String              @db.ObjectId
  lineItem          LineItem            @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  truckNumber       String
  status            String              @default("UNDER_LOADING")
  userShortageQuantity Float?
  userReceivingNote String?
  userReceivingUpdatedAt DateTime?
  userReceivingUpdatedById String?      @db.ObjectId
  deliveredItems    TruckDeliveredItem[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@unique([purchaseOrderId, truckNumber])
  @@map("truck_allocations")
}

model TruckDeliveredItem {
  id                String            @id @default(auto()) @map("_id") @db.ObjectId
  truckAllocationId String            @db.ObjectId
  truckAllocation   TruckAllocation   @relation(fields: [truckAllocationId], references: [id], onDelete: Cascade)
  lineItemId        String            @db.ObjectId
  lineItem          LineItem          @relation(fields: [lineItemId], references: [id], onDelete: Cascade)
  quantity          Float
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([truckAllocationId])
  @@unique([truckAllocationId, lineItemId])
  @@map("truck_delivered_items")
}
