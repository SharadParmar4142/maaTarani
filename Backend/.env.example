# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# MongoDB Atlas connection string
# Format: mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/DATABASE_NAME?retryWrites=true&w=majority
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/maaTarini?retryWrites=true&w=majority"

# JWT Configuration
# Change this to a strong random string in production
JWT_SECRET="your-secret-key-change-this-in-production"

# Optional: if set, admin signup requires this key
ADMIN_SIGNUP_KEY="set-a-strong-admin-signup-key"

# Instructions:
# 1. Replace "username" with your MongoDB username
# 2. Replace "password" with your MongoDB password
# 3. Replace "cluster" with your MongoDB cluster name
# 4. Generate a strong JWT_SECRET for production (use a random string generator)
